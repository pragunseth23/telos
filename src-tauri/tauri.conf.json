{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Telos",
  "version": "0.1.0",
  "identifier": "com.telos.desktop",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://localhost:4173",
    "frontendDist": ".."
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Telos",
        "width": 1400,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
